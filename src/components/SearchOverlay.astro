<div class="search-overlay" id="searchOverlay" role="dialog" aria-label="Search the wiki" aria-hidden="true">
  <div class="search-overlay-backdrop" id="searchBackdrop"></div>
  <div class="search-overlay-panel">
    <div class="search-overlay-header">
      <div class="search-overlay-input-wrap">
        <svg class="search-overlay-icon" width="20" height="20" viewBox="0 0 17 17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="7" cy="7" r="5"/><line x1="10.8" y1="10.8" x2="15.5" y2="15.5"/></svg>
        <input type="text" class="search-overlay-input" id="searchInput" placeholder="Search articles, terms, concepts...">
      </div>
      <button class="search-overlay-close" id="searchClose" aria-label="Close search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="search-overlay-results" id="searchResults">
      <div class="search-overlay-hint">Type to search across all 52 articles and 30 glossary terms</div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var base = document.querySelector('meta[name="base"]').content;
  var overlay = document.getElementById('searchOverlay');
  var input = document.getElementById('searchInput');
  var results = document.getElementById('searchResults');
  var toggle = document.getElementById('searchToggle');
  var close = document.getElementById('searchClose');
  var backdrop = document.getElementById('searchBackdrop');

  var articles = [
    { title: 'Climate Finance', category: 'CONCEPTS', desc: 'The flow of capital directed at reducing emissions and managing climate risk.', url: base + '/concepts/climate-finance/' },
    { title: 'Physical Risks', category: 'CONCEPTS', desc: 'Financial risks from the direct physical effects of climate change.', url: base + '/concepts/physical-risks/' },
    { title: 'Transition Risks', category: 'CONCEPTS', desc: 'Financial risks from the shift to a low-carbon economy.', url: base + '/concepts/transition-risks/' },
    { title: 'Stranded Assets', category: 'CONCEPTS', desc: 'Assets that have lost value due to climate policy or market shifts.', url: base + '/concepts/stranded-assets/' },
    { title: 'Net Zero vs Carbon Neutral', category: 'CONCEPTS', desc: 'A critical distinction with legal and reputational implications.', url: base + '/concepts/net-zero-vs-carbon-neutral/' },
    { title: 'Greenwashing', category: 'CONCEPTS', desc: 'Making misleading claims about environmental credentials.', url: base + '/concepts/greenwashing/' },
    { title: 'Greenwashing Typology', category: 'CONCEPTS', desc: 'Six named patterns of greenwashing and one of greenhushing.', url: base + '/concepts/greenwashing-typology/' },
    { title: 'The 1.5\u00b0C Threshold', category: 'CONCEPTS', desc: 'The Paris Agreement warming limit. Breached on an annual basis in 2024.', url: base + '/concepts/the-1.5c-threshold/' },
    { title: 'Just Transition', category: 'CONCEPTS', desc: 'Ensuring the shift to low-carbon is equitable.', url: base + '/concepts/just-transition/' },
    { title: 'Climate Litigation', category: 'CONCEPTS', desc: 'Legal risks facing companies over climate claims and inaction.', url: base + '/concepts/climate-litigation/' },
    { title: 'GHG Scopes', category: 'CONCEPTS', desc: 'Scope 1, 2, and 3 emissions classifications.', url: base + '/concepts/ghg-scopes/' },
    { title: 'Adaptation vs Mitigation', category: 'CONCEPTS', desc: 'Two fundamentally different responses to climate change.', url: base + '/concepts/adaptation-vs-mitigation/' },
    { title: 'Green Bonds', category: 'INSTRUMENTS', desc: 'The backbone of climate finance \u2014 bonds ring-fenced for environmental projects.', url: base + '/instruments/green-bonds/' },
    { title: 'Sustainability-Linked Bonds', category: 'INSTRUMENTS', desc: 'Bonds whose financial terms change if the issuer misses sustainability targets.', url: base + '/instruments/sustainability-linked-bonds/' },
    { title: 'Transition Bonds', category: 'INSTRUMENTS', desc: 'Financing for high-emitting sectors that cannot yet qualify for green bonds.', url: base + '/instruments/transition-bonds/' },
    { title: 'Carbon Offsets', category: 'INSTRUMENTS', desc: 'Credits representing one tonne of CO\u2082 reduced or removed.', url: base + '/instruments/carbon-offsets/' },
    { title: 'The Greenium', category: 'INSTRUMENTS', desc: 'The lower borrowing cost green bond issuers may achieve.', url: base + '/instruments/the-greenium/' },
    { title: 'Cap-and-Trade', category: 'INSTRUMENTS', desc: 'A hard ceiling on emissions, a market price for the right to pollute.', url: base + '/instruments/cap-and-trade/' },
    { title: 'Paris Agreement', category: 'FRAMEWORKS', desc: 'The 2015 treaty that made climate a financial obligation.', url: base + '/frameworks/paris-agreement/' },
    { title: 'TCFD', category: 'FRAMEWORKS', desc: 'The framework that made climate risk mainstream in global finance.', url: base + '/frameworks/tcfd/' },
    { title: 'IFRS S1 and S2', category: 'FRAMEWORKS', desc: 'The new global sustainability disclosure baseline.', url: base + '/frameworks/ifrs-s1-s2/' },
    { title: 'EU Taxonomy', category: 'FRAMEWORKS', desc: 'The EU\'s definition of environmentally sustainable activities.', url: base + '/frameworks/eu-taxonomy/' },
    { title: 'CSRD', category: 'FRAMEWORKS', desc: 'EU regulation mandating detailed sustainability reporting.', url: base + '/frameworks/csrd/' },
    { title: 'SFDR', category: 'FRAMEWORKS', desc: 'EU fund classification by sustainability claims.', url: base + '/frameworks/sfdr/' },
    { title: 'Green Bond Principles', category: 'FRAMEWORKS', desc: 'ICMA\'s voluntary standards for green bond issuance.', url: base + '/frameworks/green-bond-principles/' },
    { title: 'GHG Protocol', category: 'FRAMEWORKS', desc: 'International standard for corporate emissions measurement.', url: base + '/frameworks/ghg-protocol/' },
    { title: 'Kyoto Protocol', category: 'FRAMEWORKS', desc: 'The first binding climate treaty \u2014 and why it fell short.', url: base + '/frameworks/kyoto-protocol/' },
    { title: 'Montreal Protocol', category: 'FRAMEWORKS', desc: 'The treaty that actually worked.', url: base + '/frameworks/montreal-protocol/' },
    { title: 'Article 6', category: 'FRAMEWORKS', desc: 'Paris Agreement rules for international carbon markets.', url: base + '/frameworks/article-6/' },
    { title: 'Inflation Reduction Act', category: 'FRAMEWORKS', desc: 'The largest climate law in American history.', url: base + '/frameworks/inflation-reduction-act/' },
    { title: 'EU Green Deal', category: 'FRAMEWORKS', desc: 'The EU\'s carbon-neutral-by-2050 master plan.', url: base + '/frameworks/eu-green-deal/' },
    { title: 'IPCC', category: 'ACTORS', desc: 'The UN body that synthesises global climate science.', url: base + '/actors/ipcc/' },
    { title: 'UNFCCC and COP', category: 'ACTORS', desc: 'The primary international forum for climate agreements.', url: base + '/actors/unfccc-and-cop/' },
    { title: 'Mark Carney', category: 'ACTORS', desc: 'The "Tragedy of the Horizon" speech that changed finance.', url: base + '/actors/mark-carney/' },
    { title: 'GFANZ', category: 'ACTORS', desc: 'Financial alliance for net zero \u2014 $130T+ at peak.', url: base + '/actors/gfanz/' },
    { title: 'Climate Action 100+', category: 'ACTORS', desc: 'Investor coalition pressuring top corporate emitters.', url: base + '/actors/climate-action-100-plus/' },
    { title: 'CDP', category: 'ACTORS', desc: 'Corporate climate disclosure system used by investors.', url: base + '/actors/cdp/' },
    { title: 'Science Based Targets Initiative', category: 'ACTORS', desc: 'Gold standard for validating net-zero claims.', url: base + '/actors/science-based-targets-initiative/' },
    { title: 'Development Finance Institutions', category: 'ACTORS', desc: 'World Bank and regional development banks.', url: base + '/actors/development-finance-institutions/' },
    { title: 'Transition Pathway Initiative', category: 'ACTORS', desc: 'Investor benchmarking for Paris-aligned decarbonization.', url: base + '/actors/transition-pathway-initiative/' },
    { title: 'Volkswagen Dieselgate', category: 'CASE STUDIES', desc: 'The defining corporate greenwashing case \u2014 $14.7B settlement.', url: base + '/case-studies/volkswagen-dieselgate/' },
    { title: 'HSBC Greenwashing', category: 'CASE STUDIES', desc: 'When the ads said green but the portfolio said oil.', url: base + '/case-studies/hsbc-greenwashing/' },
    { title: 'DWS SEC Fine', category: 'CASE STUDIES', desc: 'First major asset manager greenwashing enforcement.', url: base + '/case-studies/dws-sec-fine/' },
    { title: 'PG&E Bankruptcy', category: 'CASE STUDIES', desc: 'Physical climate risk destroyed a $30B company.', url: base + '/case-studies/pge-bankruptcy/' },
    { title: 'ENEL SLB', category: 'CASE STUDIES', desc: 'Created the SLB market \u2014 then became its cautionary tale.', url: base + '/case-studies/enel-slb/' },
    { title: 'Seychelles Blue Bond', category: 'CASE STUDIES', desc: 'A nation of 100,000 people invented the blue bond.', url: base + '/case-studies/seychelles-blue-bond/' },
    { title: 'Marfrig Transition Bond', category: 'CASE STUDIES', desc: 'Beef producer\'s $500M bond vs Amazon deforestation.', url: base + '/case-studies/marfrig-transition-bond/' },
    { title: 'Lombard Odier', category: 'CASE STUDIES', desc: 'Ice cubes vs burning logs \u2014 a transition investing framework.', url: base + '/case-studies/lombard-odier-ice-cubes/' },
  ];

  function openSearch() {
    overlay.classList.add('active');
    overlay.setAttribute('aria-hidden', 'false');
    input.value = '';
    results.innerHTML = '<div class="search-overlay-hint">Type to search across all 52 articles and 30 glossary terms</div>';
    setTimeout(function() { input.focus(); }, 100);
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    overlay.classList.remove('active');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  if (toggle) {
    toggle.addEventListener('click', function(e) {
      e.preventDefault();
      openSearch();
    });
  }
  if (close) {
    close.addEventListener('click', closeSearch);
  }
  if (backdrop) {
    backdrop.addEventListener('click', closeSearch);
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('active')) closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  });

  if (input) {
    input.addEventListener('input', function() {
      var q = this.value.toLowerCase().trim();
      if (!q) {
        results.innerHTML = '<div class="search-overlay-hint">Type to search across all 52 articles and 30 glossary terms</div>';
        return;
      }
      var matches = articles.filter(function(a) {
        return a.title.toLowerCase().includes(q) || a.desc.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      });
      if (matches.length === 0) {
        results.innerHTML = '<div class="search-no-results">No results for \u201c' + q.replace(/</g,'&lt;') + '\u201d</div>';
        return;
      }
      results.innerHTML = matches.slice(0, 8).map(function(a) {
        return '<a href="' + a.url + '" class="search-result-item">' +
          '<span class="search-result-badge">' + a.category + '</span>' +
          '<div class="search-result-title">' + a.title + '</div>' +
          '<div class="search-result-desc">' + a.desc + '</div>' +
        '</a>';
      }).join('');
    });
  }
})();
</script>
