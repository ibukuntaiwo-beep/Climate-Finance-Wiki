---
interface Props {
  before: string[];
  after: string[];
}
const { before, after } = Astro.props;
---
<div class="before-after">
  <div class="before-after-grid">
    <div class="before-after-col">
      <h3>Before</h3>
      <ul>
        {before.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
    <div class="before-after-col">
      <h3>After</h3>
      <ul>
        {after.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</div>
