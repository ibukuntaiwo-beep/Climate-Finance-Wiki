---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/url';

const steps = [
  {
    category: "Case Study",
    title: "PG&E Bankruptcy",
    href: url('/case-studies/pge-bankruptcy/'),
    note: "A utility worth $30 billion went bankrupt because of wildfires. Start here to understand why climate change is now a financial crisis, not just an environmental one."
  },
  {
    category: "Concept",
    title: "Climate Finance",
    href: url('/concepts/climate-finance/'),
    note: "What is this field, and why does money matter in the climate story? The foundation everything else builds on."
  },
  {
    category: "Concept",
    title: "The 1.5°C Threshold",
    href: url('/concepts/the-1.5c-threshold/'),
    note: "The number that defines the stakes. Understanding why every decimal point matters changes how you read every story that follows."
  },
  {
    category: "Concept",
    title: "Physical Risks",
    href: url('/concepts/physical-risks/'),
    note: "The first way climate threatens financial assets: direct physical damage from extreme weather, flooding, and a changing climate."
  },
  {
    category: "Concept",
    title: "Transition Risks",
    href: url('/concepts/transition-risks/'),
    note: "The second way: policy changes, technology shifts, and market pressure make entire asset classes uneconomic almost overnight."
  },
  {
    category: "Actor",
    title: "Mark Carney and the Tragedy of the Horizon",
    href: url('/actors/mark-carney/'),
    note: "The 2015 speech that moved climate risk from an environmental concern to a mainstream financial obligation."
  },
  {
    category: "Case Study",
    title: "HSBC Greenwashing",
    href: url('/case-studies/hsbc-greenwashing/'),
    note: "How a major bank responded to climate pressure with a poster campaign — and got banned by the advertising regulator for it."
  },
  {
    category: "Concept",
    title: "Greenwashing",
    href: url('/concepts/greenwashing/'),
    note: "What it is, why it proliferated, and why it is now regulated across advertising, investment products, and corporate disclosure."
  },
  {
    category: "Framework",
    title: "TCFD",
    href: url('/frameworks/tcfd/'),
    note: "The framework that made climate disclosure mainstream, and the template for almost every disclosure standard that followed."
  },
  {
    category: "Case Study",
    title: "Engine No. 1 vs ExxonMobil",
    href: url('/case-studies/engine-no-1-exxonmobil/'),
    note: "How a $40 million stake took on the world's largest oil company — and won three board seats by persuading the institutions that couldn't sell."
  },
  {
    category: "Case Study",
    title: "Seychelles Blue Bond",
    href: url('/case-studies/seychelles-blue-bond/'),
    note: "What good climate finance looks like in practice: a small island state pioneering an instrument the world is still learning from."
  }
];

const nextPaths = [
  {
    name: "The Greenwashing Trail",
    tagline: "From misleading claims to criminal charges.",
    href: url('/concepts/greenwashing/')
  },
  {
    name: "Follow the Money",
    tagline: "How climate finance actually flows, and where it gets stuck.",
    href: url('/concepts/climate-finance/')
  },
  {
    name: "Architecture of Climate Policy",
    tagline: "The agreements, taxonomies, and standards that set the rules.",
    href: url('/frameworks/paris-agreement/')
  }
];
---
<BaseLayout title="Start Here | Climate Finance Wiki" footerType="internal">

  <header class="path-header">
    <div class="path-header-inner">
      <div class="path-label">Editor's Recommended Path</div>
      <h1>New to climate finance?<br>Start here.</h1>
      <p class="path-intro">A curated path through the cases, concepts, and turning points that explain how climate became the defining financial story of our time. Eleven articles, no prior knowledge needed.</p>
    </div>
  </header>

  <div class="path-body">

    <ol class="path-steps">
      {steps.map((step, i) => (
        <li class="path-step reveal">
          <div class="path-step-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="path-step-content">
            <div class="path-step-meta">
              <span class={`path-step-badge path-step-badge--${step.category.toLowerCase().replace(' ', '-')}`}>{step.category}</span>
            </div>
            <a href={step.href} class="path-step-title">{step.title}</a>
            <p class="path-step-note">{step.note}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="path-next reveal">
      <div class="section-label">Where to Go Next</div>
      <p class="path-next-intro">You now have the foundation. Pick a trail to go deeper.</p>
      <div class="path-next-grid">
        {nextPaths.map(trail => (
          <a href={trail.href} class="path-next-card">
            <div class="path-next-name">{trail.name}</div>
            <div class="path-next-tagline">{trail.tagline}</div>
            <span class="path-next-cta">Start &rarr;</span>
          </a>
        ))}
      </div>
    </div>

  </div>

</BaseLayout>

<style>
.path-header {
  background: var(--color-bg-secondary);
  padding: 80px 32px 60px;
  border-bottom: 1px solid var(--color-border);
}
.path-header-inner {
  max-width: 680px;
  margin: 0 auto;
}
.path-label {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  margin-bottom: 16px;
}
.path-header h1 {
  font-family: var(--font-display);
  font-size: 2.25rem;
  font-weight: 700;
  line-height: 1.15;
  color: var(--color-text-primary);
  margin: 0 0 20px;
}
.path-intro {
  font-size: 1.0625rem;
  color: var(--color-text-secondary);
  line-height: 1.65;
  margin: 0;
}

.path-body {
  max-width: 780px;
  margin: 0 auto;
  padding: 60px 32px 80px;
}

.path-steps {
  list-style: none;
  margin: 0 0 80px;
  padding: 0;
}
.path-step {
  display: flex;
  gap: 28px;
  padding: 28px 0;
  border-bottom: 1px solid var(--color-border);
}
.path-step:first-child {
  border-top: 1px solid var(--color-border);
}
.path-step-num {
  font-family: var(--font-mono);
  font-size: 0.8125rem;
  font-weight: 700;
  color: var(--color-text-muted);
  letter-spacing: 0.05em;
  padding-top: 3px;
  min-width: 28px;
}
.path-step-content {
  flex: 1;
}
.path-step-meta {
  margin-bottom: 8px;
}
.path-step-badge {
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  padding: 3px 8px;
  border-radius: 3px;
}
.path-step-badge--case-study {
  background: #fef3c7;
  color: #92400e;
}
.path-step-badge--concept {
  background: #dbeafe;
  color: #1e40af;
}
.path-step-badge--framework {
  background: #d1fae5;
  color: #065f46;
}
.path-step-badge--actor {
  background: #ede9fe;
  color: #4c1d95;
}
.path-step-title {
  display: block;
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text-primary);
  text-decoration: none;
  margin-bottom: 8px;
  line-height: 1.3;
}
.path-step-title:hover {
  color: var(--color-accent);
}
.path-step-note {
  font-size: 0.9375rem;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin: 0;
}

.path-next {
  border-top: 2px solid var(--color-border);
  padding-top: 48px;
}
.path-next-intro {
  font-size: 0.9375rem;
  color: var(--color-text-secondary);
  margin: 12px 0 32px;
}
.path-next-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.path-next-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 20px;
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.path-next-card:hover {
  border-color: var(--color-accent);
  box-shadow: var(--shadow-card);
}
.path-next-name {
  font-family: var(--font-display);
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--color-text-primary);
}
.path-next-tagline {
  font-size: 0.8125rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
  flex: 1;
}
.path-next-cta {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-accent);
  margin-top: 4px;
}

@media (max-width: 768px) {
  .path-header { padding: 60px 20px 40px; }
  .path-header h1 { font-size: 1.75rem; }
  .path-body { padding: 40px 20px 60px; }
  .path-next-grid { grid-template-columns: 1fr; }
  .path-step { gap: 16px; }
}
</style>
