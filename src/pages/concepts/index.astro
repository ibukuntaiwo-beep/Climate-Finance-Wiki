---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';
import { getCollection } from 'astro:content';
import { categories } from '../../data/categories';

const catData = categories.find(c => c.slug === 'concepts')!;
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter(a => a.data.category === 'concepts')
  .sort((a, b) => {
    const aFoundational = catData.foundational.includes(a.id) ? 0 : 1;
    const bFoundational = catData.foundational.includes(b.id) ? 0 : 1;
    return aFoundational - bFoundational;
  });
const otherCategories = categories.filter(c => c.slug !== 'concepts');
---
<BaseLayout title="Concepts | Climate Finance Wiki" footerType="internal">
  <div class="breadcrumb" aria-label="Breadcrumb">
    <ol class="breadcrumb__list">
      <li><a href={url('/')} class="breadcrumb__link">Home</a></li>
      <li class="breadcrumb__separator" aria-hidden="true">&rarr;</li>
      <li class="breadcrumb__current" aria-current="page">Concepts</li>
    </ol>
  </div>
  <header class="category-header">
    <div class="category-header__label">Concepts</div>
    <h1 class="category-header__title">Concepts</h1>
    <p class="category-header__description">{catData.description}</p>
    <div class="category-header__meta"><span>{articles.length}</span>&nbsp;articles&ensp;&middot;&ensp;<span>{catData.connectionCount}</span>&nbsp;connections</div>
  </header>
  <div class="category-banner" aria-hidden="true">
    <img class="category-banner__img" src={catData.photo} alt="Concepts category" loading="eager">
    <div class="category-banner__overlay"></div>
    <span class="category-banner__caption">{catData.caption}</span>
  </div>
  <div class="content-area">
    <main class="main-column" id="articles">
      {articles.map((article) => {
        const isFoundational = catData.foundational.includes(article.id);
        return (
          <article class={`article-card ${isFoundational ? 'article-card--featured' : ''}`}>
            <a href={url(`/concepts/${article.id}/`)} class="article-card__link">
              {isFoundational && (
                <div class="article-card__top-row">
                  <span class="article-card__foundational">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    Foundational
                  </span>
                </div>
              )}
              <h2 class="article-card__title">{article.data.title}</h2>
              <p class="article-card__subtitle">{article.data.subtitle}</p>
              <div class="article-card__footer">
                <span class="article-card__stats"><span>{article.data.seeAlso.length}</span>&nbsp;connections</span>
                <span class="article-card__read-cta">Read&ensp;&rarr;</span>
              </div>
            </a>
          </article>
        );
      })}
    </main>
    <aside class="sidebar" aria-label="Category context">
      <div class="sidebar-box">
        <h2 class="sidebar-box__heading">Related Categories</h2>
        {otherCategories.map(cat => (
          <a href={url(`/${cat.slug}/`)} class="related-cat">
            <span class="related-cat__name">{cat.name}</span>
            <span class="related-cat__count">{cat.articleCount} articles</span>
          </a>
        ))}
      </div>
    </aside>
  </div>
  <script>
    (function(){var p=window.matchMedia('(prefers-reduced-motion: reduce)').matches;var c=document.querySelectorAll('.article-card');if(p){c.forEach(function(d){d.classList.add('is-visible')});return}if('IntersectionObserver' in window){var o=new IntersectionObserver(function(e){e.forEach(function(en){if(en.isIntersecting){en.target.classList.add('is-visible');o.unobserve(en.target)}})},{threshold:0.15,rootMargin:'0px 0px -40px 0px'});c.forEach(function(d){o.observe(d)})}else{c.forEach(function(d){d.classList.add('is-visible')})}})();
  </script>
</BaseLayout>
