---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { findTrailForArticle } from '../../data/trails';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles');
  return allArticles.filter(a => a.data.category === 'concepts').map(article => ({
    params: { slug: article.id },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const trail = findTrailForArticle('concepts', article.id);
const tocSections = headings.filter(h => h.depth === 2).map(h => ({ id: h.slug, title: h.text }));
---
<ArticleLayout
  title={article.data.title}
  subtitle={article.data.subtitle}
  category="Concepts"
  categorySlug="concepts"
  stats={article.data.stats}
  seeAlso={article.data.seeAlso}
  unexpected={article.data.unexpected}
  sources={article.data.sources}
  trail={trail}
  tocSections={tocSections}
>
  <Content />
</ArticleLayout>
